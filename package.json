{
  "name": "microservices-api",
  "version": "1.0.0",
  "description": "API REST con microservicios usando Node.js, Express y MongoDB",
  "main": "server.js",
  "scripts": {
    "start": "node --no-deprecation simple-server.js",
    "dev": "nodemon --no-deprecation simple-server.js",
    "dev:old": "node --no-deprecation server.js",
    "microservices": "node --no-deprecation microservices/start-microservices.js",
    "microservices:dev": "nodemon --no-deprecation microservices/start-microservices.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "worker:email": "node workers/start-email-worker.js",
    "worker:push": "node workers/start-push-worker.js",
    "debug:push": "node scripts/debug-push-notifications.js",
    "get:device": "node scripts/get-device.js",
    "check:push-queue": "node scripts/check-push-queue.js",
    "sqs:create-queue": "node scripts/create-sqs-queue.js",
    "sqs:create-push-queue": "node scripts/create-push-sqs-queue.js",
    "db:add-indexes": "node scripts/add-recommended-indexes.js",
    "db:create-notification-index": "node scripts/create-notification-backoffice-index.js",
    "migrate:fix-form-responses": "node scripts/fix-form-responses-preguntaid.js",
    "email:resend:institution-welcome": "node scripts/resend-institution-welcome-email.js",
    "email:upload-assets-s3": "node scripts/upload-email-assets-to-s3.js",
    "s3:public-email-assets-policy": "node scripts/s3-public-email-assets-policy.js",
    "email:test-images": "node scripts/send-test-email-images.js"
  },
  "keywords": [
    "node",
    "express",
    "mongodb",
    "microservices",
    "api",
    "rest"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.940.0",
    "@aws-sdk/client-cloudwatch": "^3.940.0",
    "@aws-sdk/client-ecs": "^3.940.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.940.0",
    "@aws-sdk/client-s3": "^3.879.0",
    "@aws-sdk/client-ses": "^3.879.0",
    "@aws-sdk/client-sqs": "^3.879.0",
    "@aws-sdk/client-wafv2": "^3.940.0",
    "apn": "^2.2.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "firebase-admin": "^12.0.0",
    "form-data": "^4.0.4",
    "googleapis": "^159.0.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "multer-s3": "^2.10.0",
    "nodemailer": "^7.0.6",
    "qrcode": "^1.5.4",
    "redis": "^5.8.3",
    "sharp": "^0.34.3",
    "speakeasy": "^2.0.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
